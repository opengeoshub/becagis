{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Remove __pycache__",
      "type": "shell",
      "command": "Get-ChildItem -Path . -Recurse -Directory -Filter '__pycache__' | Remove-Item -Recurse -Force",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
